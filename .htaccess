# OVH / Apache
Options -Indexes
ErrorDocument 404 /404.php

# Routes / redirects
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Deny access to secrets / private files (defense in depth if uploaded).
  RewriteRule (^|/)\.env(?:\..*)?$ - [F,L,NC]
  RewriteRule (^|/)\.git - [F,L,NC]
  RewriteRule (^|/)\.DS_Store$ - [F,L,NC]
  RewriteRule \.ppk$ - [F,L,NC]
  RewriteRule \.pem$ - [F,L,NC]
  RewriteRule \.key$ - [F,L,NC]
  RewriteRule ^(?:Dockerfile|docker-compose.*\.yml|\.dockerignore|init\.sql)$ - [F,L,NC]

  # Canonicalize entrypoints (keep clean URLs; preserve query string by default)
  RewriteCond %{THE_REQUEST} \s/+[^?\s]*index\.php(?:\?|\s) [NC]
  RewriteRule ^index\.php$ / [R=302,L]
  RewriteCond %{THE_REQUEST} \s/+[^?\s]*land\.php(?:\?|\s) [NC]
  RewriteRule ^land\.php$ /land [R=302,L]
  RewriteCond %{THE_REQUEST} \s/+[^?\s]*shore\.php(?:\?|\s) [NC]
  RewriteRule ^shore\.php$ /shore [R=302,L]
  RewriteCond %{THE_REQUEST} \s/+[^?\s]*bato\.php(?:\?|\s) [NC]
  RewriteRule ^bato\.php$ /bato [R=302,L]
  RewriteCond %{THE_REQUEST} \s/+[^?\s]*silence\.php(?:\?|\s) [NC]
  RewriteRule ^silence\.php$ /silence [R=302,L]
  RewriteCond %{THE_REQUEST} \s/+[^?\s]*dashboard\.php(?:\?|\s) [NC]
  RewriteRule ^dashboard\.php$ /dashboard [R=302,L]
  RewriteCond %{THE_REQUEST} \s/+[^?\s]*echo\.php(?:\?|\s) [NC]
  RewriteRule ^echo\.php$ /echo [R=302,L]
  RewriteCond %{THE_REQUEST} \s/+[^?\s]*str3m\.php(?:\?|\s) [NC]
  RewriteRule ^str3m\.php$ /str3m [R=302,L]

  # AZA: canonicalize query-step URL to /aza/<n>
  RewriteCond %{THE_REQUEST} \s/+[^?\s]*aza\.php\?p=([0-9]{1,2}) [NC]
  RewriteCond %{QUERY_STRING} ^p=([0-9]{1,2})$ [NC]
  RewriteRule ^aza\.php$ /aza/%1? [R=302,L]
  RewriteCond %{THE_REQUEST} \s/+[^?\s]*aza\.php(?:\?|\s) [NC]
  RewriteRule ^aza\.php$ /aza [R=302,L]

  # Canonicalize trailing slash on entry paths
  RewriteRule ^(install|land|shore|bato|silence|dashboard|aza|echo|str3m)/$ /$1 [R=302,L,NC]

  # If the request is an existing file/dir, serve it as-is.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Aliases (planned entries)
  RewriteRule ^board$ /dashboard [R=302,L,NC]
  RewriteRule ^machine$ /aza [R=302,L,NC]
  RewriteRule ^start$ /install [R=302,L,NC]

  # Clean entry paths -> PHP pages
  RewriteRule ^install$ index.php [L,NC]
  RewriteRule ^land$ land.php [L,NC]
  RewriteRule ^shore$ shore.php [L,NC]
  RewriteRule ^bato$ bato.php [L,NC]
  RewriteRule ^silence$ silence.php [L,NC]
  RewriteRule ^dashboard$ dashboard.php [L,NC]
  RewriteRule ^aza$ aza.php [L,NC]
  RewriteRule ^echo$ echo.php [L,NC,QSA]
  RewriteRule ^str3m$ str3m.php [L,NC]

  # P0RT: /port/{12-char slug}
  RewriteRule ^port/([a-f0-9]{12})$ port.php?slug=$1 [L,NC,QSA]

  # AZA steps: /aza/1 .. /aza/5
  RewriteRule ^aza/0*([0-9]{1,2})$ aza.php?p=$1 [L,NC,QSA]
</IfModule>

# Passer en prod (si autorisÃ©)
# SetEnv APP_ENV prod

# SÃ©curitÃ© basique
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "DENY"
  Header set Referrer-Policy "no-referrer"
</IfModule>

Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

  RewriteRule (^|/)\.env(?:\..*)?$ - [F,L,NC]
  RewriteRule (^|/)\.git - [F,L,NC]
  RewriteRule (^|/)\.DS_Store$ - [F,L,NC]
  RewriteRule \.ppk$ - [F,L,NC]
  RewriteRule \.pem$ - [F,L,NC]
  RewriteRule \.key$ - [F,L,NC]
  RewriteRule ^(?:Dockerfile|docker-compose.*\.yml|\.dockerignore|init\.sql)$ - [F,L,NC]

  RewriteCond %{THE_REQUEST} \s/+[^?\s]*index\.php(?:\?|\s) [NC]
  RewriteRule ^index\.php$ https://%{HTTP_HOST}/ [R=302,L]
  RewriteCond %{THE_REQUEST} \s/+[^?\s]*land\.php(?:\?|\s) [NC]
  RewriteRule ^land\.php$ https://%{HTTP_HOST}/land [R=302,L]
  RewriteCond %{THE_REQUEST} \s/+[^?\s]*echo\.php(?:\?|\s) [NC]
  RewriteRule ^echo\.php$ https://%{HTTP_HOST}/echo [R=302,L]
  RewriteCond %{THE_REQUEST} \s/+[^?\s]*map\.php(?:\?|\s) [NC]
  RewriteRule ^map\.php$ https://%{HTTP_HOST}/map [R=302,L]
  RewriteCond %{THE_REQUEST} \s/+[^?\s]*signal\.php(?:\?|\s) [NC]
  RewriteRule ^signal\.php$ https://%{HTTP_HOST}/signal [R=302,L]
  RewriteCond %{THE_REQUEST} \s/+[^?\s]*str3m\.php(?:\?|\s) [NC]
  RewriteRule ^str3m\.php$ https://%{HTTP_HOST}/str3m [R=302,L]
  RewriteCond %{THE_REQUEST} \s/+[^?\s]*aza\.php(?:\?|\s) [NC]
  RewriteRule ^aza\.php$ https://%{HTTP_HOST}/aza [R=302,L]
  RewriteCond %{THE_REQUEST} \s/+[^?\s]*island\.php(?:\?|\s) [NC]
  RewriteRule ^island\.php$ https://%{HTTP_HOST}/island [R=302,L]
  RewriteCond %{THE_REQUEST} \s/+[^?\s]*rejoindre\.php(?:\?|\s) [NC]
  RewriteRule ^rejoindre\.php$ https://%{HTTP_HOST}/rejoindre [R=302,L]
  RewriteCond %{THE_REQUEST} \s/+[^?\s]*0wlslw0\.php(?:\?|\s) [NC]
  RewriteRule ^0wlslw0\.php$ https://%{HTTP_HOST}/0wlslw0 [R=302,L]
  RewriteCond %{THE_REQUEST} \s/+[^?\s]*sh0re\.php(?:\?|\s) [NC]
  RewriteRule ^sh0re\.php$ https://%{HTTP_HOST}/sh0re [R=302,L]
  RewriteCond %{THE_REQUEST} \s/+[^?\s]*n\.php(?:\?|\s) [NC]
  RewriteRule ^n\.php$ https://%{HTTP_HOST}/n [R=302,L]
  RewriteCond %{THE_REQUEST} \s/+[^?\s]*n0de\.php(?:\?|\s) [NC]
  RewriteRule ^n0de\.php$ https://%{HTTP_HOST}/n0de [R=302,L]
  RewriteCond %{THE_REQUEST} \s/+[^?\s]*ingest_sensor\.php(?:\?|\s) [NC]
  RewriteRule ^ingest_sensor\.php$ https://%{HTTP_HOST}/ingest/sensor [R=302,L]

  RewriteRule ^0wlslw0/voice/$ https://%{HTTP_HOST}/0wlslw0/voice [R=302,L,NC]
  RewriteRule ^(land|echo|map|signal|str3m|aza|island|rejoindre|0wlslw0|sh0re|n|n0de)/$ https://%{HTTP_HOST}/$1 [R=302,L,NC]
  RewriteRule ^ingest/sensor/$ https://%{HTTP_HOST}/ingest/sensor [R=302,L,NC]

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule ^$ index.php [L]
  RewriteRule ^land$ land.php [L,NC,QSA]
  RewriteRule ^echo$ echo.php [L,NC,QSA]
  RewriteRule ^map/points/?$ map_points.php [L,NC,QSA]
  RewriteRule ^map$ map.php [L,NC,QSA]
  RewriteRule ^signal$ signal.php [L,NC,QSA]
  RewriteRule ^str3m$ str3m.php [L,NC,QSA]
  RewriteRule ^aza$ aza.php [L,NC,QSA]
  RewriteRule ^island$ island.php [L,NC,QSA]
  RewriteRule ^rejoindre$ rejoindre.php [L,NC,QSA]
  RewriteRule ^sh0re$ sh0re.php [L,NC,QSA]
  RewriteRule ^n$ n.php [L,NC,QSA]
  RewriteRule ^n0de$ n0de.php [L,NC,QSA]
  RewriteRule ^ingest/sensor$ ingest_sensor.php [L,NC,QSA]
  RewriteRule ^0wlslw0/voice$ 0wlslw0_voice.php [L,NC,QSA]
  RewriteRule ^0wlslw0$ 0wlslw0.php [L,NC,QSA]
  RewriteRule ^aza/0*([0-9]{1,2})$ aza.php?p=$1 [L,NC,QSA]
</IfModule>

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "DENY"
  Header set Referrer-Policy "no-referrer"
</IfModule>

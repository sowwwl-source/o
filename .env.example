SOWWWL_PUBLIC_ORIGIN=https://sowwwl.com
SOWWWL_AZA_STORAGE_DIR=/var/www/runtime/aza
# Optional override for public Str3m / signals storage.
# SOWWWL_SIGNALS_DIR=/var/www/runtime/signals
SOWWWL_AZA_MAX_UPLOAD_BYTES=2147483648
# Optional: browser-facing URL for the visitor guide / DigitalOcean chat relay.
# Use a public chat page or wrapper, not the raw agent API endpoint.
# SOWWWL_0WLSLW0_CHAT_URL=https://your-public-chat-url
# Voice-only relay to the real 0wlslw0 agent.
# These values are used server-side only by /0wlslw0/voice.
# Leave them blank to stay on local fallback.
# When you fill them, verify with:
# php scripts/check_0wlslw0_agent.php --require-remote-ok
# SOWWWL_0WLSLW0_AGENT_ENDPOINT=https://your-agent-endpoint.agents.do-ai.run
# SOWWWL_0WLSLW0_AGENT_KEY=replace-with-endpoint-key
# SOWWWL_0WLSLW0_AGENT_AUTH_HEADER=Authorization
# SOWWWL_0WLSLW0_AGENT_AUTH_SCHEME=Bearer
# SOWWWL_0WLSLW0_AGENT_MODE=chat
# SOWWWL_0WLSLW0_AGENT_INPUT_FIELD=message
# SOWWWL_0WLSLW0_AGENT_TIMEOUT_SECONDS=18
# Décommente et ajuste quand le sous-domaine direct pointe vers le VPS :
# SOWWWL_AZA_DIRECT_ORIGIN=https://upload.sowwwl.com
# Optional override for the browser -> plasma bridge. Leave unset to keep it local to the current host.
# SOWWWL_MEMBRANE_BRIDGE_URL=https://sowwwl.xyz/ingest/membrane
# Optional override for the public plasma feed. Leave unset to keep it local to the current host.
# SOWWWL_PLASMA_FEED_URL=https://sowwwl.xyz/plasma/recent
# Optional comma-separated browser origins for the public plasma endpoints when you intentionally cross origins.
# SOWWWL_PLASMA_ALLOWED_ORIGINS=https://sowwwl.xyz

# 3ternet lab / Raspberry Pi sensor ingest.
# Never keep the example value in production.
# SOWWWL_PI_TOKEN=replace-with-long-random-token
# SOWWWL_SENSOR_LOG_DIR=/var/www/runtime/plasma

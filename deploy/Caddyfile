{
	email {$ACME_EMAIL:ops@sowwwl.cloud}
}

(common_headers) {
	encode zstd gzip
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}
}

(permissions_static) {
	header {
		Permissions-Policy "camera=(), geolocation=(), microphone=()"
	}
}

(permissions_interactive) {
	header {
		Permissions-Policy "accelerometer=(self), ambient-light-sensor=(self), camera=(), geolocation=(), gyroscope=(self), magnetometer=(self), microphone=(self), screen-wake-lock=(self)"
	}
}

(permissions_surface) {
	header {
		Permissions-Policy "accelerometer=(self), ambient-light-sensor=(self), camera=(self), geolocation=(), gyroscope=(self), magnetometer=(self), microphone=(self), screen-wake-lock=(self)"
	}
}

www.sowwwl.cloud {
	redir https://sowwwl.cloud{uri} 308
}

sowwwl.xyz {
	import common_headers
	import permissions_surface
	reverse_proxy app:80
}

www.sowwwl.xyz {
	redir https://sowwwl.xyz{uri} 308
}

sowwwl.cloud {
	import common_headers
	import permissions_static
	root * /srv/sites/sowwwl.cloud
	file_server
}

api.sowwwl.cloud {
	encode zstd gzip
	header {
		Access-Control-Allow-Origin *
		Access-Control-Allow-Headers "Authorization, Content-Type"
		Access-Control-Allow-Methods "GET, POST, OPTIONS"
		X-Content-Type-Options nosniff
		Referrer-Policy no-referrer
		-Server
	}
	@preflight method OPTIONS
	respond @preflight 204
	reverse_proxy api:80
}

0.user.o.sowwwl.cloud {
	import common_headers
	import permissions_static
	root * /srv/sites/0.user.o.sowwwl.cloud
	try_files {path} {path}/ /index.html
	file_server
}


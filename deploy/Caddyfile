{
	email {$ACME_EMAIL}
}

(common_headers) {
	encode zstd gzip
	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "camera=(), geolocation=(), microphone=()"
		-Server
	}
}

(static_security_headers) {
	header {
		Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' https://api.sowwwl.cloud; font-src 'self' data:; form-action 'self'; upgrade-insecure-requests"
		Cross-Origin-Opener-Policy same-origin
		Cross-Origin-Resource-Policy same-origin
		Origin-Agent-Cluster ?1
	}
}

# Domaines actifs. DNS manquant : api.sowwwl.cloud (ajouter A → 161.35.157.37).
# Exclus volontairement (pas de DNS / pas de contenu) :
# - 0.user.o.sowwwl.cloud
# - 0wlslw0.fr  (second droplet 164.92.220.248 — Caddyfile séparé)

www.sowwwl.cloud {
	redir https://sowwwl.cloud{uri} 308
}

sowwwl.cloud {
	import common_headers
	reverse_proxy app:80

	handle_errors {
	    rewrite * /error.html
	    file_server
	}
}

www.o.sowwwl.cloud {
	redir https://o.sowwwl.cloud{uri} 308
}

o.sowwwl.cloud {
	import common_headers
	reverse_proxy app:80

	handle_errors {
	    rewrite * /error.html
	    file_server
	}
}

api.sowwwl.cloud {
	import common_headers
	reverse_proxy api:80
}

www.sowwwl.me {
	redir https://sowwwl.me{uri} 308
}

sowwwl.me {
	import common_headers
	import static_security_headers
	root * /srv/sites/sowwwl.me
	file_server
}


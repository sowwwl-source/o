(common_headers) {
	encode zstd gzip
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "camera=(), geolocation=(), microphone=()"
		-Server
	}
}

www.sowwwl.cloud {
	redir https://sowwwl.cloud{uri} 308
}

sowwwl.xyz {
	import common_headers
	header {
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; connect-src 'self'; manifest-src 'self'; worker-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; object-src 'none'"
		Cross-Origin-Opener-Policy same-origin
		Cross-Origin-Resource-Policy same-origin
		X-Permitted-Cross-Domain-Policies none
	}
	reverse_proxy app:80
}

www.sowwwl.xyz {
	redir https://sowwwl.xyz{uri} 308
}

sowwwl.cloud {
	import common_headers
	root * /srv/sites/sowwwl.cloud
	file_server
}

api.sowwwl.cloud {
	encode zstd gzip
	header {
		Access-Control-Allow-Origin *
		Access-Control-Allow-Headers "Authorization, Content-Type"
		Access-Control-Allow-Methods "GET, POST, OPTIONS"
		X-Content-Type-Options nosniff
		Referrer-Policy no-referrer
		-Server
	}
	@preflight method OPTIONS
	respond @preflight 204
	reverse_proxy api:80
}

0.user.o.sowwwl.cloud {
	import common_headers
	root * /srv/sites/0.user.o.sowwwl.cloud
	try_files {path} {path}/ /index.html
	file_server
}


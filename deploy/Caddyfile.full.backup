{
	email {$ACME_EMAIL}
}

(common_headers) {
	encode zstd gzip
	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "camera=(), geolocation=(), microphone=()"
		-Server
	}
}

(static_security_headers) {
	header {
		Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' https://api.sowwwl.cloud; font-src 'self' data:; form-action 'self'; upgrade-insecure-requests"
		Cross-Origin-Opener-Policy same-origin
		Cross-Origin-Resource-Policy same-origin
		Origin-Agent-Cluster ?1
	}
}

www.sowwwl.cloud {
	redir https://sowwwl.cloud{uri} 308
}

sowwwl.cloud {
	import common_headers
	import static_security_headers
	root * /srv/sites/sowwwl.cloud
	file_server
}

www.sowwwl.me {
	redir https://sowwwl.me{uri} 308
}

sowwwl.me {
	import common_headers
	import static_security_headers
	root * /srv/sites/sowwwl.me
	file_server
}

api.sowwwl.cloud {
	encode zstd gzip
	header {
		X-Content-Type-Options nosniff
		Referrer-Policy no-referrer
		-Server
	}
	reverse_proxy api:80
}

0.user.o.sowwwl.cloud {
	import common_headers
	import static_security_headers
	root * /srv/sites/0.user.o.sowwwl.cloud
	try_files {path} {path}/ /index.html
	file_server
}

www.sowwwl.org {
	redir https://sowwwl.org{uri} 308
}

sowwwl.org {
	import common_headers
	import static_security_headers
	root * /srv/sites/sowwwl.org
	file_server
}

www.0wlslw0.com {
	redir https://0wlslw0.com{uri} 308
}

0wlslw0.com {
	import common_headers
	import static_security_headers
	root * /srv/sites/0wlslw0.com
	file_server
}

www.0wlslw0.fr {
	redir https://0wlslw0.fr{uri} 308
}

0wlslw0.fr {
	import common_headers
	import static_security_headers
	root * /srv/sites/0wlslw0.com
	file_server
}

www.sowwwl.com {
	redir https://sowwwl.com{uri} 308
}

sowwwl.com {
	import common_headers
	reverse_proxy app:80
}

www.sowwwl.art {
	redir https://sowwwl.art{uri} 308
}

sowwwl.art {
	import common_headers
	import static_security_headers
	root * /srv/sites/0wlslw0.com
	file_server
}

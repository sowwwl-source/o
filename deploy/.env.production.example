ACME_EMAIL=ops@sowwwl.cloud
AZA_API_TOKEN=CHANGE_ME_API_TOKEN
DB_NAME=o
DB_USER=user
DB_PASS=CHANGE_ME_DB_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_DB_PASSWORD
SOWWWL_PUBLIC_ORIGIN=https://sowwwl.com
SOWWWL_ADMIN_PIN=CHANGE_ME_ADMIN_PIN
SOWWWL_ADMIN_EMAIL=pablo@sowwwl.com
SOWWWL_AZA_DIRECT_ORIGIN=https://upload.sowwwl.com
SOWWWL_0WLSLW0_CHAT_URL=
SOWWWL_0WLSLW0_AGENT_ENDPOINT=
SOWWWL_0WLSLW0_AGENT_KEY=
SOWWWL_0WLSLW0_AGENT_AUTH_HEADER=Authorization
SOWWWL_0WLSLW0_AGENT_AUTH_SCHEME=Bearer
SOWWWL_0WLSLW0_AGENT_MODE=chat
SOWWWL_0WLSLW0_AGENT_INPUT_FIELD=message
SOWWWL_0WLSLW0_AGENT_EXTRA_HEADERS_JSON=
SOWWWL_0WLSLW0_AGENT_TIMEOUT_SECONDS=18

# Magic link login (allowlisted emails)
SOWWWL_MAGIC_LINK_EMAILS=pablo@sowwwl.com,0wlslw0@protonmail.com
SOWWWL_MAGIC_LINK_SECRET=CHANGE_ME_MAGIC_LINK_SECRET
# log (default), mail, display (dev only)
SOWWWL_MAGIC_LINK_DELIVERY=log
# Keep Signal aligned with the deployed mode unless you explicitly cut over to SMTP mail.
SOWWWL_SIGNAL_IDENTITY_DELIVERY=log
# Only needed when Signal identity delivery switches to mail.
SOWWWL_MAGIC_LINK_FROM=no-reply@sowwwl.com
SOWWWL_MAGIC_LINK_FROM_NAME=sowwwl

# SMTP (required when SOWWWL_SIGNAL_IDENTITY_DELIVERY=mail)
SOWWWL_SMTP_HOST=smtp.example.com
SOWWWL_SMTP_PORT=587
SOWWWL_SMTP_USERNAME=CHANGE_ME_SMTP_USER
SOWWWL_SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
# tls (default), ssl, none
SOWWWL_SMTP_ENCRYPTION=tls
